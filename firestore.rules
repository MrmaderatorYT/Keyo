rules_version = '2';

// Правила безпеки Firestore для Keyo.
// Кожен користувач бачить ЛИШЕ власний профіль та власні записи.
// Нагадування: навіть якщо ці правила обійти, у документах лежать лише
// AES-256-GCM-шифротексти — розшифрувати їх без майстер-пароля неможливо.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
